# ── MCP Bridge auth token ───────────────────────────────────────────────────
# Generate a strong random token, e.g.:
#   openssl rand -hex 32
MCP_AUTH_TOKEN=replace-me-with-a-long-random-secret

# ── Path to project on the Pi host ─────────────────────────────────────────
# This is the folder that gets mounted into the container as /project
# Adjust to wherever you cloned / copied the project on the Pi
PROJECT_ROOT_HOST=/home/pi/SN-knowledge-upload

# ── ServiceNow credentials ──────────────────────────────────────────────────
SN_INSTANCE=https://your-instance.service-now.com
SN_USERNAME=your_sn_user
SN_PASSWORD=your_sn_password
SN_KB_SYS_ID=your_kb_sys_id

# ── Anthropic API key (for vision pipeline) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── IGT Standard reference fields ───────────────────────────────────────────
# Copy these from sn-igt-upload/.env (they are sys_ids from your SN instance)
SN_ICW_ASSIGNMENT_TYPE=functional_location
SN_IGT_OWNER_GROUP=your_owner_group_sys_id
SN_IGT_LOCATION=your_location_sys_id
SN_IGT_FUNCTIONAL_LOCATIONS=your_functional_location_sys_id
SN_IGT_CATEGORY=your_category_sys_id
